<?xml version="1.0" encoding="utf-8"?>
<!--
    Intentionally exclude all backup — this is a local-only privacy app.
    No data should ever leave the device via backup mechanisms.
-->
<full-backup-content>
    <exclude domain="database" path="." />
    <exclude domain="sharedpref" path="." />
    <exclude domain="file" path="." />
</full-backup-content>
